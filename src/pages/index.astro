---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="BetterActs Collective">

<Nav />

<!-- ============================================ -->
<!-- HERO                                         -->
<!-- ============================================ -->
<section class="min-h-screen flex items-center pt-20 pb-16 md:pb-24 bg-cream">
  <div class="max-w-7xl mx-auto px-6 md:px-10 grid md:grid-cols-2 gap-12 md:gap-16 items-center">
    <div class="fade-in">
      <h1 class="font-heading font-bold text-[40px] md:text-[64px] leading-[1.1] text-dark mb-6">
        Australia's small Not-for-profits and charities do&nbsp;the&nbsp;most.
      </h1>
      <p class="text-xl md:text-2xl text-dark/80 font-medium mb-4 font-heading" style="font-variation-settings: 'opsz' 20;">
        We help them do it without the admin&nbsp;chaos.
      </p>
      <a href="/get-in-touch" class="inline-flex items-center px-7 py-3.5 rounded-full bg-orange text-white font-semibold text-base btn-hover">
        Get in Touch
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="fade-in hidden md:block" style="transition-delay: 0.15s;">
      <!-- Warm abstract SVG: community, hands, connection -->
      <svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-md mx-auto">
        <!-- Background circle -->
        <circle cx="250" cy="250" r="220" fill="#FDF0E4"/>
        <!-- Connection arcs -->
        <path d="M140 300 Q180 200 250 210 Q320 220 340 300" stroke="#E8782A" stroke-width="3" fill="none" opacity="0.4"/>
        <path d="M120 320 Q180 240 250 250 Q320 260 360 320" stroke="#C4550A" stroke-width="2" fill="none" opacity="0.3"/>
        <!-- Central warm shape -->
        <ellipse cx="250" cy="260" rx="80" ry="70" fill="#E8782A" opacity="0.12"/>
        <!-- People/community circles -->
        <circle cx="180" cy="200" r="32" fill="#E8782A" opacity="0.8"/>
        <circle cx="180" cy="200" r="20" fill="#FDF0E4"/>
        <circle cx="180" cy="194" r="8" fill="#E8782A" opacity="0.7"/>
        <path d="M162 212 Q180 230 198 212" stroke="#E8782A" stroke-width="2.5" fill="none" opacity="0.6"/>
        <circle cx="320" cy="200" r="32" fill="#C4550A" opacity="0.75"/>
        <circle cx="320" cy="200" r="20" fill="#FDF0E4"/>
        <circle cx="320" cy="194" r="8" fill="#C4550A" opacity="0.7"/>
        <path d="M302 212 Q320 230 338 212" stroke="#C4550A" stroke-width="2.5" fill="none" opacity="0.6"/>
        <circle cx="250" cy="160" r="36" fill="#E8782A" opacity="0.9"/>
        <circle cx="250" cy="160" r="22" fill="#FDF0E4"/>
        <circle cx="250" cy="153" r="9" fill="#E8782A" opacity="0.7"/>
        <path d="M230 172 Q250 192 270 172" stroke="#E8782A" stroke-width="2.5" fill="none" opacity="0.6"/>
        <!-- Hands reaching toward center -->
        <path d="M130 350 Q160 310 200 300 Q220 295 235 310" stroke="#E8782A" stroke-width="4" stroke-linecap="round" fill="none" opacity="0.6"/>
        <path d="M370 350 Q340 310 300 300 Q280 295 265 310" stroke="#C4550A" stroke-width="4" stroke-linecap="round" fill="none" opacity="0.6"/>
        <!-- Heart in center -->
        <path d="M240 300 Q240 285 250 280 Q260 285 260 300 L250 315 Z" fill="#E8782A" opacity="0.5"/>
        <!-- Small connecting dots -->
        <circle cx="210" cy="240" r="4" fill="#E8782A" opacity="0.4"/>
        <circle cx="290" cy="240" r="4" fill="#C4550A" opacity="0.4"/>
        <circle cx="250" cy="220" r="4" fill="#E8782A" opacity="0.3"/>
        <circle cx="230" cy="270" r="3" fill="#C4550A" opacity="0.3"/>
        <circle cx="270" cy="270" r="3" fill="#E8782A" opacity="0.3"/>
        <!-- Dotted connection lines -->
        <line x1="200" y1="190" x2="230" y2="170" stroke="#E8782A" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.3"/>
        <line x1="300" y1="190" x2="270" y2="170" stroke="#C4550A" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.3"/>
        <line x1="195" y1="215" x2="235" y2="240" stroke="#E8782A" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.25"/>
        <line x1="305" y1="215" x2="265" y2="240" stroke="#C4550A" stroke-width="1.5" stroke-dasharray="4 4" opacity="0.25"/>
        <!-- Warm accent shapes -->
        <circle cx="150" cy="150" r="12" fill="#E8782A" opacity="0.1"/>
        <circle cx="360" cy="140" r="16" fill="#C4550A" opacity="0.08"/>
        <circle cx="390" cy="380" r="10" fill="#E8782A" opacity="0.1"/>
        <circle cx="110" cy="390" r="14" fill="#C4550A" opacity="0.08"/>
      </svg>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!-- STATS                                        -->
<!-- ============================================ -->
<section class="bg-cream py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <p class="fade-in text-xs md:text-sm uppercase tracking-[0.2em] font-semibold text-muted-text mb-12 md:mb-16 text-center">
      The problem isn't passion. It's infrastructure.
    </p>
    <div class="grid md:grid-cols-3 gap-10 md:gap-16 mb-12 md:mb-16">
      <div class="fade-in text-center">
        <span class="font-heading text-5xl md:text-6xl font-bold text-orange counter" data-target="65">0</span><span class="font-heading text-5xl md:text-6xl font-bold text-orange">%</span>
        <p class="text-base font-semibold text-dark mt-3 mb-1">of Australian charities are small</p>
        <p class="text-sm text-muted-text leading-relaxed">Most get almost no operational support.</p>
      </div>
      <div class="fade-in text-center" style="transition-delay: 0.1s;">
        <span class="font-heading text-5xl md:text-6xl font-bold text-orange counter" data-target="50">0</span><span class="font-heading text-5xl md:text-6xl font-bold text-orange">%</span>
        <p class="text-base font-semibold text-dark mt-3 mb-1">run entirely by volunteers</p>
        <p class="text-sm text-muted-text leading-relaxed">No budget for operational staff.</p>
      </div>
      <div class="fade-in text-center" style="transition-delay: 0.2s;">
        <span class="font-heading text-5xl md:text-6xl font-bold text-orange counter" data-target="40">0</span><span class="font-heading text-5xl md:text-6xl font-bold text-orange">%</span>
        <p class="text-base font-semibold text-dark mt-3 mb-1">can't implement digital tools</p>
        <p class="text-sm text-muted-text leading-relaxed">Priced out by enterprise software.</p>
      </div>
    </div>
    <p class="fade-in text-center text-base md:text-lg text-muted-text max-w-2xl mx-auto leading-relaxed">
      The sector is full of people giving everything. They deserve support that matches that commitment.
    </p>
  </div>
</section>

<!-- ============================================ -->
<!-- ORIGIN                                       -->
<!-- ============================================ -->
<section class="bg-white py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-6 md:px-10 grid md:grid-cols-2 gap-12 md:gap-20 items-center">
    <div class="fade-in">
      <p class="text-xs md:text-sm uppercase tracking-[0.2em] font-semibold text-muted-text mb-4">Why we exist</p>
      <h2 class="font-heading text-[32px] md:text-[44px] font-bold text-dark mb-6 leading-tight">
        We didn't study this&nbsp;problem. We&nbsp;lived&nbsp;it.
      </h2>
      <p class="text-base md:text-lg text-muted-text leading-relaxed mb-6">
        BetterActs Collective was founded by three active volunteers and not-for-profit operators. They hit the same walls every small not-for-profit hits: too much admin, not enough support, tools built for organisations ten times their size. So they built what they needed. And made it available to everyone else.
      </p>
      <a href="/team" class="inline-flex items-center text-orange font-semibold text-base hover:text-amber transition-colors">
        Meet the team →
      </a>
    </div>
    <div class="fade-in hidden md:flex justify-center" style="transition-delay: 0.15s;">
      <!-- Abstract warm SVG: growth, togetherness -->
      <svg viewBox="0 0 440 440" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-sm">
        <rect x="40" y="40" width="360" height="360" rx="40" fill="#FDF0E4"/>
        <!-- Overlapping organic shapes -->
        <ellipse cx="200" cy="230" rx="100" ry="90" fill="#E8782A" opacity="0.12"/>
        <ellipse cx="260" cy="210" rx="90" ry="80" fill="#C4550A" opacity="0.1"/>
        <!-- Seed / growth motif -->
        <path d="M220 320 Q220 240 180 190 Q200 170 220 190 Q240 170 260 190 Q220 240 220 320Z" fill="#E8782A" opacity="0.25"/>
        <!-- Branching lines upward -->
        <path d="M220 250 Q190 200 170 160" stroke="#E8782A" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.4"/>
        <path d="M220 250 Q250 200 270 160" stroke="#C4550A" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.4"/>
        <path d="M220 270 Q200 230 180 200" stroke="#E8782A" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.3"/>
        <path d="M220 270 Q240 230 260 200" stroke="#C4550A" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.3"/>
        <!-- Leaf shapes -->
        <ellipse cx="165" cy="155" rx="18" ry="10" transform="rotate(-30 165 155)" fill="#E8782A" opacity="0.35"/>
        <ellipse cx="275" cy="155" rx="18" ry="10" transform="rotate(30 275 155)" fill="#C4550A" opacity="0.3"/>
        <ellipse cx="175" cy="195" rx="14" ry="8" transform="rotate(-20 175 195)" fill="#E8782A" opacity="0.25"/>
        <ellipse cx="265" cy="195" rx="14" ry="8" transform="rotate(20 265 195)" fill="#C4550A" opacity="0.25"/>
        <!-- Small accent circles -->
        <circle cx="160" cy="140" r="5" fill="#E8782A" opacity="0.5"/>
        <circle cx="280" cy="140" r="5" fill="#C4550A" opacity="0.5"/>
        <circle cx="220" cy="130" r="4" fill="#E8782A" opacity="0.3"/>
        <!-- Ground line -->
        <path d="M140 330 Q180 320 220 325 Q260 330 300 320" stroke="#E8782A" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.2"/>
      </svg>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!-- WHAT WE DO - TEASER                          -->
<!-- ============================================ -->
<section class="bg-cream py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <h2 class="fade-in font-heading text-[32px] md:text-[44px] font-bold text-dark text-center mb-14 md:mb-20">
      One mission. Two ways we&nbsp;show&nbsp;up.
    </h2>
    <div class="grid md:grid-cols-2 gap-6 md:gap-8">
      <!-- Tool panel -->
      <div class="fade-in bg-muted-tint rounded-2xl p-8 md:p-10 flex flex-col">
        <p class="text-xs uppercase tracking-[0.2em] font-semibold text-amber mb-4">Tool</p>
        <h3 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4 leading-tight">
          Volunteer Management Tool
        </h3>
        <p class="text-base text-muted-text leading-relaxed mb-6 flex-1">
          Simple, affordable volunteer management software built for real budgets.
        </p>
        <a href="/programs" class="inline-flex items-center text-orange font-semibold text-base hover:text-amber transition-colors self-start">
          Learn more →
        </a>
      </div>
      <!-- Community panel -->
      <div class="fade-in bg-white rounded-2xl p-8 md:p-10 flex flex-col" style="transition-delay: 0.1s;">
        <p class="text-xs uppercase tracking-[0.2em] font-semibold text-amber mb-4">Community</p>
        <h3 class="font-heading text-2xl md:text-3xl font-bold text-dark mb-4 leading-tight">
          Peer Events and Programs
        </h3>
        <p class="text-base text-muted-text leading-relaxed mb-6 flex-1">
          Community-led learning for not-for-profit operators. Launching 2026.
        </p>
        <a href="/programs" class="inline-flex items-center text-orange font-semibold text-base hover:text-amber transition-colors self-start">
          Learn more →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!-- VISION                                       -->
<!-- ============================================ -->
<section class="relative bg-dark py-28 md:py-40 grain-overlay overflow-hidden">
  <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-10 text-center">
    <p class="fade-in font-heading text-2xl md:text-[40px] leading-[1.3] text-white/90 font-medium mb-8">
      Small Not-for-profits shouldn't have to choose between running their operations and running their&nbsp;mission.
    </p>
    <p class="fade-in font-heading text-xl md:text-2xl text-white font-bold" style="transition-delay: 0.15s;">
      We exist so they don't have&nbsp;to.
    </p>
  </div>
</section>

<!-- ============================================ -->
<!-- FINAL CTA                                    -->
<!-- ============================================ -->
<section class="bg-orange py-24 md:py-32">
  <div class="max-w-3xl mx-auto px-6 md:px-10 text-center">
    <h2 class="fade-in font-heading text-[32px] md:text-[44px] font-bold text-white mb-6 leading-tight">
      We're early. That means you can shape&nbsp;this.
    </h2>
    <p class="fade-in text-base md:text-lg text-white/90 leading-relaxed mb-10 max-w-2xl mx-auto" style="transition-delay: 0.1s;">
      Whether you're a Not-for-profit looking for better tools, a funder who believes in sector equity, or someone who just gets it - we want to hear from you.
    </p>
    <a href="/get-in-touch" class="fade-in inline-flex items-center px-8 py-4 rounded-full bg-white text-dark font-bold text-base btn-hover mb-8" style="transition-delay: 0.15s;">
      Get in Touch
      <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<Footer />

<!-- ============================================ -->
<!-- SCRIPTS                                      -->
<!-- ============================================ -->
<script>
  // IntersectionObserver for fade-in animations
  const fadeEls = document.querySelectorAll('.fade-in');
  const fadeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        fadeObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

  fadeEls.forEach(el => fadeObserver.observe(el));

  // Counter animation
  const counters = document.querySelectorAll('.counter');
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        let current = 0;
        const duration = 1500;
        const step = target / (duration / 16);
        const animate = () => {
          current += step;
          if (current >= target) {
            el.textContent = target.toString();
          } else {
            el.textContent = Math.floor(current).toString();
            requestAnimationFrame(animate);
          }
        };
        requestAnimationFrame(animate);
        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  counters.forEach(c => counterObserver.observe(c));
</script>

</Layout>
