---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Programs - BetterActs Collective">

<Nav />

<!-- ============================================ -->
<!-- PAGE INTRO                                   -->
<!-- ============================================ -->
<section class="bg-cream pt-32 md:pt-40 pb-24 md:pb-32">
  <div class="max-w-4xl mx-auto px-6 md:px-10">
    <div class="fade-in">
      <h1 class="font-heading font-bold text-[40px] md:text-[64px] leading-[1.1] text-dark mb-8">
        What We Do
      </h1>
      <p class="text-xl md:text-2xl text-dark/80 font-medium font-heading" style="font-variation-settings: 'opsz' 20;">
        One mission. Two ways we show up.
      </p>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!-- VOLUNTEER MANAGEMENT TOOL                    -->
<!-- ============================================ -->
<section class="bg-white py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="fade-in">
      <p class="text-xs md:text-sm uppercase tracking-[0.2em] font-semibold text-sage mb-4">Volunteer Management Tool</p>
      <h2 class="font-heading text-[32px] md:text-[44px] font-bold text-dark mb-6 leading-tight">
        Lori
      </h2>
      <p class="text-base md:text-lg text-muted-text leading-relaxed mb-8 max-w-3xl">
        Most small not-for-profits manage their volunteers through spreadsheets and group chats. Our volunteer management tool changes that. Simple, affordable, and built for real budgets and real missions.
      </p>

      <div class="mb-8">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-dark/70 bg-muted-tint rounded-full px-4 py-1.5">
          <span class="text-green-600">&#10003;</span> Live today. Two organisations already onboard.
        </span>
      </div>
      <a href="https://www.getlori.tech" target="_blank" rel="noopener noreferrer" class="inline-flex items-center px-7 py-3.5 rounded-full bg-orange text-white font-semibold text-base btn-hover">
        Visit Lori
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ============================================ -->
<!-- PEER EVENTS & PROGRAMS                       -->
<!-- ============================================ -->
<section class="bg-cream py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="fade-in">
      <p class="text-xs md:text-sm uppercase tracking-[0.2em] font-semibold text-sage mb-4">Community</p>
      <h2 class="font-heading text-[32px] md:text-[44px] font-bold text-dark mb-6 leading-tight">
        Peer Events and Programs
      </h2>
      <p class="text-base md:text-lg text-muted-text leading-relaxed mb-8 max-w-3xl">
        Community-led learning for not-for-profit operators. Honest conversations about what works, run by people inside the sector. Not consultants parachuted in from outside.
      </p>
      <div class="mb-8">
        <span class="inline-flex items-center gap-2 text-sm font-medium text-dark/70 bg-white/60 rounded-full px-4 py-1.5">
          <span class="text-muted-text">&#9676;</span> Launching 2026
        </span>
      </div>
      <a href="/get-in-touch" class="inline-flex items-center px-7 py-3.5 rounded-full bg-orange text-white font-semibold text-base btn-hover">
        Stay in touch
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<Footer />

<script>
  const fadeEls = document.querySelectorAll('.fade-in');
  const fadeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        fadeObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
  fadeEls.forEach(el => fadeObserver.observe(el));
</script>

</Layout>
